# ============================================================
# SUPABASE CONFIGURATION - BACKEND SERVER
# ============================================================
# IMPORTANT: Backend MUST use service_role secret key (sb_secret_*)
# NOT the anon/public key (sb_publishable_)
# 
# Why? Backend operations that bypass RLS need the service_role key:
# - Storing password history
# - User registration
# - Admin operations
# 
# The anon/public key is for frontend-only operations.

# Your Supabase project URL (format: https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Secret Key (REQUIRED - must start with sb_secret_)
# How to get:
#   1. Go to https://app.supabase.com
#   2. Select your project
#   3. Click Settings → API
#   4. Find "service_role secret" section
#   5. Copy the entire key (it's ~95 characters)
#   6. Paste below
# 
# Format example:
#   sb_secret_abcdef123456ghijkl789opqrst0uvwxyz1234567890abc
SUPABASE_KEY=sb_secret_your_actual_service_role_key_here
# ============================================================
# SECURITY CONFIGURATION
# ============================================================
# JWT Secret for FastAPI authentication and password hashing
# Generate a strong random string (NOT a Supabase key!)
# 
# How to generate:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# Should be 32+ characters, random, alphanumeric
SECRET_KEY=your_random_secret_key_here_at_least_32_chars_long

# ============================================================
# API CONFIGURATION
# ============================================================
API_VERSION=1.0.0

# ============================================================
# DEPRECATED/LEGACY (do not use)
# ============================================================
# SUPABASE_KEY=sb_publishable_e-09e6CUJq_p8-QqL9uvMA_uDXZoSDN  # ❌ Don't use anon/public for backend
# SECRET_KEY=sb_secret_xxx  # ❌ Wrong format for JWT secret

# ============================================================
# TROUBLESHOOTING
# ============================================================
# If you see "Invalid Supabase key for backend":
#   1. Check SUPABASE_KEY starts with "sb_secret_"
#   2. If it starts with "sb_publishable_", get the service_role instead
#   3. Make sure you copied the FULL key (not truncated)
#   4. Make sure no spaces or quotes
#
# If you see "Invalid API key" error:
#   1. Verify the key is correct in Supabase console
#   2. Check key hasn't been revoked
#   3. Ensure you copied the full key
#
# If tables are missing:
#   1. Run schema.sql in Supabase SQL Editor
#   2. Ensure RLS policies are set if you enabled RLS
